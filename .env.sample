# Copy this file to .env and fill in your values
# Get your API key at https://openrouter.ai/keys

# Required
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional — override the model used for plan generation
# Find free models at https://openrouter.ai/models?q=free
VITE_MODEL=mistralai/mistral-small-3.1-24b-instruct:free

# Optional — HTTP-Referer header sent to OpenRouter (identifies your app)
VITE_HTTP_REFERER=https://ai-fitness-planner.local

# Optional — X-Title header shown in OpenRouter dashboard
VITE_APP_TITLE=AI Fitness Planner

# Optional — override the system prompt sent to the model
# VITE_SYSTEM_PROMPT=You are an elite AI fitness coach...
